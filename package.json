{
  "name": "metar-explorer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "run-s --continue-on-error fmt oxlint",
    "lint:check": "run-s fmt:check oxlint:check",
    "oxlint": "oxlint --fix",
    "oxlint:check": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "npm-check-updates": "npx taze major --maturity-period 2",
    "npm-check-updates:install": "npx taze major -w --maturity-period 2 && npm install",
    "typecheck": "nuxt prepare && vue-tsc",
    "code-quality": "npx fallow"
  },
  "dependencies": {
    "@fontsource/syne": "^5.2.7",
    "@fontsource/syne-mono": "^5.2.7",
    "@tailwindcss/vite": "^4.2.2",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.6"
  }
}
